<script>
// ========================
// DATA
// ========================
let COURTS = ['Sân 1','Sân 2','Sân 3','Sân 4','Sân 5'];
let HOURS = ['06:00','07:00','08:00','09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00','20:00','21:00'];
// APPS_SCRIPT_URL via env var

function sendToSheet(booking) {
  try {
    const params = new URLSearchParams({
      id: booking.id || '',
      name: booking.name || '',
      phone: booking.phone || '',
      date: booking.date || '',
      court: booking.court || '',
      startHour: booking.startHour || '',
      duration: String(booking.duration || ''),
      players: String(booking.players || ''),
      rackets: String(booking.rackets || 0),
      courtTotal: String(booking.courtTotal || 0),
      racketTotal: String(booking.racketTotal || 0),
      total: String(booking.total || 0),
      status: booking.status || 'pending',
      payment: booking.payment || 'cash',
      note: booking.note || ''
    });

    const target = '/api/sheet?' + params.toString();
    console.log('Gửi Sheet:', target);

    fetch(target)
      .then(r => r.json())
      .then(d => console.log('Sheet OK:', d))
      .catch(err => console.warn('Gửi Sheet lỗi:', err.message));

  } catch(e) {
    console.warn('Gửi Sheet thất bại:', e);
  }
}
function _sheetCb(data) { console.log('Sheet response:', data); }

async function loadBookingsFromSheet(dateFilter) {
  try {
    // Lazy load: chỉ fetch ngày đang chọn + hôm nay nếu không có filter
    const targetDate = dateFilter || selectedDate || dates[0];
    const url = targetDate
      ? `/api/sheet?action=readJson&date=${encodeURIComponent(targetDate)}`
      : '/api/sheet?action=read';
    const res = await fetch(url);
    if (!res.ok) { console.warn('Sheet HTTP error:', res.status); return; }
    const payload = await res.json();
    // readJson trả { bookings: [], ts: ... }, read trả array thẳng
    const rows = Array.isArray(payload) ? payload : (payload.bookings || []);
    if (!Array.isArray(rows)) { console.warn('Sheet response lỗi:', payload); return; }

    function parseDate(val) {
      if (!val) return '';
      const s = String(val).trim();
      if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
      if (s.includes('T')) {
        const d = new Date(s);
        const offset = d.getTimezoneOffset();
        d.setMinutes(d.getMinutes() - offset);
        return d.toISOString().split('T')[0];
      }
      return s;
    }

    function parseHour(val) {
      if (!val) return '';
      const s = String(val).trim();
      // "08:00" → OK
      if (/^\d{2}:00$/.test(s)) return s;
      // "08:18" hoặc "08:30" → normalize về "08:00" (giờ tròn)
      if (/^\d{2}:\d{2}$/.test(s)) return s.substring(0,2) + ':00';
      // ISO datetime
      if (s.includes('T')) {
        const d = new Date(s);
        return String(d.getUTCHours()).padStart(2,'0') + ':00';
      }
      // Số thuần: 15 → "15:00", 6 → "06:00"
      if (/^\d{1,2}$/.test(s)) return s.padStart(2,'0') + ':00';
      // "15:00:00" → "15:00"
      if (/^\d{2}:\d{2}:\d{2}$/.test(s)) return s.substring(0,2) + ':00';
      return s;
    }

    bookings = rows
      .filter(r => r && r.id)
      .map(r => ({
        id:          String(r.id          || ''),
        name:        String(r.name        || ''),
        phone:       String(r.phone       || ''),
        email:       String(r.email       || ''),
        date:        parseDate(r.date     || ''),
        court:       String(r.court       || ''),
        startHour:   parseHour(r.startHour|| ''),
        duration:    Number(r.duration)   || 1,
        players:     Number(r.players)    || 4,
        rackets:     Number(r.rackets)    || 0,
        courtTotal:  Number(r.courtTotal) || 0,
        racketTotal: Number(r.racketTotal)|| 0,
        total:       Number(r.total)      || 0,
        status:      String(r.status      || 'pending'),
        payment:     String(r.payment     || ''),
        note:        String(r.note        || '')
      }));

    if (!_isConfirming) buildGrid();
        console.log('[Sheet] Loaded', bookings.length, 'bookings');
  } catch(e) {
    console.warn('[Sheet] loadBookings error:', e.message);
  }
}

let PRICE_DAY = 120000;   // 06:00 – 16:00
let PRICE_NIGHT = 220000; // 17:00 – 22:00
let PRICE_RACKET = 30000; // /cây/giờ

// ── MEMBERSHIP TIER ──────────────────────────────────────────
const TIER_CONFIG = {
  black:   { discount: 5,  label: '⚫ Black',   color: '#8B949E', bg: 'rgba(139,148,158,0.15)' },
  silver:  { discount: 8,  label: '⚪ Silver',  color: '#C0C0C0', bg: 'rgba(192,192,192,0.15)' },
  gold:    { discount: 10, label: '🥇 Gold',    color: '#F39C12', bg: 'rgba(243,156,18,0.15)'  },
  diamond: { discount: 15, label: '💎 Diamond', color: '#3498DB', bg: 'rgba(52,152,219,0.15)'  }
};
function getTierDiscount() {
  if (!currentMember) return 0;
  // Fallback: nếu tier undefined (GAS cũ không trả tier) → black = 5%
  const tier = currentMember.tier || 'black';
  return TIER_CONFIG[tier]?.discount ?? TIER_CONFIG.black.discount;
}
const MAX_PLAYERS = 4;

function getPriceForHour(hour) {
  const h         = parseInt(hour);
  const nightHour = (window._nightHour !== undefined) ? window._nightHour : 17;
  return h >= nightHour ? PRICE_NIGHT : PRICE_DAY;
}

let bookings = [];

let selectedSlots = []; // [{court, hour, date}]
let selectedDate = getTodayStr();
let selectedPlayers = 4;
let selectedRackets = 0;
let currentFilter = 'all';

function calcTotal(slots) {
  // slots: [{court, hour, date}]
  return slots.reduce((sum, s) => sum + getPriceForHour(s.hour), 0);
}

function calcTotalForCourtHours(hours) {
  return hours.reduce((sum, h) => sum + getPriceForHour(h), 0);
}

// ========================
// UTILS
// ========================
function getTodayStr() {
  return new Date().toISOString().split('T')[0];
}

function formatDate(str) {
  const d = new Date(str + 'T00:00:00');
  return d.toLocaleDateString('vi-VN', { weekday: 'long', day: '2-digit', month: '2-digit', year: 'numeric' });
}

function formatMoney(n) {
  return n.toLocaleString('vi-VN') + 'đ';
}

function genId() {
  // Timestamp (giây) + random 3 chữ số → không trùng kể cả đặt cùng lúc
  const ts  = Math.floor(Date.now() / 1000).toString(36).toUpperCase().slice(-4);
  const rnd = Math.floor(Math.random() * 1000).toString().padStart(3, '0');
  return 'BK' + ts + rnd;
}

function isBooked(date, court, hour) {
  return bookings.some(b => {
    if (b.date !== date || b.court !== court || b.status === 'cancelled') return false;
    const start = HOURS.indexOf(b.startHour);
    if (start < 0) return false;
    for (let i = 0; i < b.duration; i++) {
      if (HOURS[start + i] === hour) return true;
    }
    return false;
  });
}

function getBookingInfo(date, court, hour) {
  return bookings.find(b => {
    if (b.date !== date || b.court !== court || b.status === 'cancelled') return false;
    const start = HOURS.indexOf(b.startHour);
    if (start < 0) return false;
    for (let i = 0; i < b.duration; i++) {
      if (HOURS[start + i] === hour) return true;
    }
    return false;
  });
}

function isSelected(date, court, hour) {
  return selectedSlots.some(s => s.date === date && s.court === court && s.hour === hour);
}

// ========================
// DATE STRIP
// ========================
function buildDateStrip() {
  const strip = document.getElementById('dateStrip');
  strip.innerHTML = '';
  const today = new Date();
  const days = ['CN','T2','T3','T4','T5','T6','T7'];
  for (let i = 0; i < 14; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() + i);
    const str = d.toISOString().split('T')[0];
    const btn = document.createElement('button');
    btn.className = 'date-btn' + (str === selectedDate ? ' active' : '');
    btn.innerHTML = `<div class="day">${days[d.getDay()]}</div><div class="num">${d.getDate()}</div>`;
    btn.onclick = () => {
      selectedDate = str;
      clearSelection();
      buildDateStrip();
      buildGrid();
    };
    strip.appendChild(btn);
  }
}

// ========================
// COURT GRID
// ========================
function buildGrid() {
  const head = document.getElementById('courtHead');
  const body = document.getElementById('courtBody');

  // Header
  let headHTML = '<tr><th>GIỜ</th>';
  COURTS.forEach(c => { headHTML += `<th>${c}</th>`; });
  headHTML += '</tr>';
  head.innerHTML = headHTML;

  // Body
  let bodyHTML = '';
  HOURS.forEach(hour => {
    const isNight = parseInt(hour) >= 17;
    const price = getPriceForHour(hour);
    bodyHTML += `<tr>`;
    bodyHTML += `<td>
      <div style="display:flex;flex-direction:column;gap:1px">
        <span>${hour}</span>
        <span style="font-size:0.65rem;color:${isNight?'#F39C12':'var(--text2)'}">${isNight?'🌙':'🌤'} ${formatMoney(price)}</span>
      </div>
    </td>`;
    COURTS.forEach(court => {
      const booked = isBooked(selectedDate, court, hour);
      const selected = isSelected(selectedDate, court, hour);

      // Member Silver trở lên: đặt sát giờ (chỉ lock khi slot ĐÃ QUA)
      // Black / guest: lock 30 phút trước
      const now = new Date();
      const todayStr = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
      const slotHour = parseInt(hour);
      const slotStartMs = new Date(`${selectedDate}T${String(slotHour).padStart(2,'0')}:00:00`).getTime();
      const canBookLastMinute = currentMember && ['silver','gold','diamond'].includes(currentMember.tier);
      const isPast = selectedDate === todayStr && (
        canBookLastMinute
          ? Date.now() > slotStartMs                       // Silver+: chỉ lock khi đã qua
          : Date.now() > slotStartMs - 30 * 60 * 1000     // Black/guest: lock 30 phút trước
      );

      let cls = 'slot ';
      let label = '';
      if (isPast && !booked) {
        cls += 'past';
        label = '—';
      } else if (selected) { cls += 'selected'; label = '✓'; }
      else if (booked) {
        cls += 'booked';
        const info = getBookingInfo(selectedDate, court, hour);
        label = info ? info.name.split(' ').pop() : 'Đã đặt';
      } else {
        cls += 'available';
        label = '+';
      }

      const disabled = (booked && !selected) || isPast ? 'disabled' : '';
      const nightStyle = isNight && !booked && !selected && !isPast ? 'border-color:rgba(243,156,18,0.4);color:#F39C12' : '';
      bodyHTML += `<td><button class="${cls}" style="${nightStyle}" ${disabled} onclick="toggleSlot('${court}','${hour}')">${label}</button></td>`;
    });
    bodyHTML += '</tr>';
  });
  body.innerHTML = bodyHTML;
}

// ========================
// SELECTION
// ========================
function toggleSlot(court, hour) {
  const idx = selectedSlots.findIndex(s => s.date === selectedDate && s.court === court && s.hour === hour);
  if (idx >= 0) {
    // Bỏ chọn — luôn cho phép
    selectedSlots.splice(idx, 1);
  } else {
    // Thêm — kiểm tra liên tiếp
    const sameCourt = selectedSlots.filter(s => s.court === court && s.date === selectedDate);
    if (sameCourt.length > 0) {
      const existingHours = sameCourt.map(s => parseInt(s.hour));
      const newHour       = parseInt(hour);
      const allHours      = [...existingHours, newHour].sort((a,b) => a-b);
      const isConsecutive = allHours.every((h,i) => i === 0 || h - allHours[i-1] === 1);
      if (!isConsecutive) {
        showNotification('⚠️ Chỉ được đặt giờ liên tiếp trên cùng một sân', 'warning');
        return;
      }
    }
    selectedSlots.push({ date: selectedDate, court, hour });
  }
  updateBookingPanel();
  buildGrid();
}

function clearSelection() {
  selectedSlots = [];
  updateBookingPanel();
  buildGrid();
}

function updateBookingPanel() {
  const panel = document.getElementById('bookingPanel');
  const summary = document.getElementById('bookingSummary');
  if (selectedSlots.length === 0) {
    panel.classList.remove('show');
    document.body.classList.remove('panel-open');
    return;
  }
  panel.classList.add('show');
  document.body.classList.add('panel-open');

  const byCourt = {};
  selectedSlots.forEach(s => {
    if (!byCourt[s.court]) byCourt[s.court] = [];
    byCourt[s.court].push(s.hour);
  });

  const total = calcTotal(selectedSlots);
  const perPerson = selectedPlayers > 0 ? Math.round(total / selectedPlayers) : 0;
  const parts = Object.entries(byCourt).map(([c, hrs]) => `${c}: ${hrs.sort().join(', ')}`);
  summary.innerHTML = `
    <div style="color:var(--text2);font-size:0.8rem">${parts.join(' &nbsp;|&nbsp; ')}</div>
    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
      <strong>${selectedSlots.length} giờ &nbsp;·&nbsp; ${selectedPlayers} người</strong>
      <span style="color:var(--green);font-weight:700">${formatMoney(total)}</span>
      <span style="color:var(--text2);font-size:0.8rem">(${formatMoney(perPerson)}/người)</span>
    </div>
  `;
}

// ========================
// MODAL
// ========================
function openModal() {
  if (selectedSlots.length === 0) return;

  const byCourt = {};
  selectedSlots.forEach(s => {
    if (!byCourt[s.court]) byCourt[s.court] = [];
    byCourt[s.court].push(s.hour);
  });

  const lines = Object.entries(byCourt).map(([c, hrs]) => {
    const subtotal = calcTotalForCourtHours(hrs.sort());
    return `<strong>${c}</strong>: ${hrs.join(' – ')} &nbsp;<span style="color:var(--green)">${formatMoney(subtotal)}</span>`;
  }).join('<br>');

  document.getElementById('modalInfo').innerHTML = `
    📅 <strong>${formatDate(selectedDate)}</strong><br>
    🏟️ ${lines}<br>
    <span style="font-size:0.75rem;color:var(--text2)">🌤 Ban ngày 120k/giờ &nbsp;·&nbsp; 🌙 Tối 220k/giờ</span>
  `;
  document.getElementById('modalPriceBox').innerHTML = buildPriceBox(selectedPlayers, selectedSlots);

  selectedPlayers = 4;
  selectedRackets = 0;
  document.querySelectorAll('.player-btn').forEach((btn, i) => {
    btn.classList.toggle('active', i + 2 === selectedPlayers);
  });
  document.getElementById('racketCount').textContent = '0';
  document.getElementById('modalPriceBox').innerHTML = buildPriceBox(selectedPlayers, selectedSlots, selectedRackets);
  document.getElementById('inputName').value = '';
  document.getElementById('inputPhone').value = '';
  document.getElementById('inputNote').value = '';
  document.getElementById('bookingModal').classList.add('show');
}

function changeRackets(delta) {
  const totalHours = selectedSlots.length;
  const maxRackets = selectedPlayers * totalHours > 0 ? selectedPlayers : 4;
  selectedRackets = Math.max(0, Math.min(selectedRackets + delta, maxRackets));
  document.getElementById('racketCount').textContent = selectedRackets;
  document.getElementById('modalPriceBox').innerHTML = buildPriceBox(selectedPlayers, selectedSlots, selectedRackets);
}

function buildPriceBox(players, slots, rackets) {
  const courtTotal = calcTotal(slots);
  const totalHours = slots.length;
  const racketTotal = rackets * PRICE_RACKET * totalHours;
  const grandTotal = courtTotal + racketTotal;
  const perPerson = players > 0 ? Math.round(grandTotal / players) : 0;

  const byCourt = {};
  slots.forEach(s => {
    if (!byCourt[s.court]) byCourt[s.court] = [];
    byCourt[s.court].push(s.hour);
  });
  const courtRows = Object.entries(byCourt).map(([c, hrs]) => {
    const sub = calcTotalForCourtHours(hrs);
    return `<div style="display:flex;justify-content:space-between;font-size:0.82rem"><span style="color:var(--text2)">${c} · ${hrs.length}h</span><span>${formatMoney(sub)}</span></div>`;
  }).join('');

  const racketRow = rackets > 0 ? `
    <div style="display:flex;justify-content:space-between;font-size:0.82rem">
      <span style="color:var(--text2)">🏓 ${rackets} vợt · ${totalHours}h</span>
      <span>${formatMoney(racketTotal)}</span>
    </div>` : '';

  return `
    <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:0.75rem">
      ${courtRows}${racketRow}
    </div>
    <div style="height:1px;background:var(--border);margin-bottom:0.75rem"></div>
    <div style="display:flex;justify-content:space-between;align-items:center">
      <div>
        <div style="font-size:0.75rem;color:var(--text2)">Tổng thanh toán</div>
        <div style="font-family:'Be Vietnam Pro',sans-serif;font-size:2rem;font-weight:700;letter-spacing:0;color:var(--green)">${formatMoney(grandTotal)}</div>
      </div>

    </div>
  `;
}

function setPlayers(n) {
  selectedPlayers = n;
  document.querySelectorAll('.player-btn').forEach((btn, i) => {
    btn.classList.toggle('active', i + 2 === n);
  });
  document.getElementById('modalPriceBox').innerHTML = buildPriceBox(n, selectedSlots, selectedRackets);
  updateBookingPanel();
}

function closeModal() {
  document.getElementById('bookingModal').classList.remove('show');
}


// ── Race condition prevention ──
// Reload fresh data từ sheet, check locally với status filter đúng
// Tránh false-positive từ Apps Script checkSlot (trả sai khi booking cũ đã cancelled)
async function checkSlotAvailability(newBookings) {
  try {
    // Reload fresh bookings từ sheet
    await loadBookingsFromSheet();
  } catch(e) {
    console.warn('[checkSlot] reload error:', e.message);
  }

  for (const b of newBookings) {
    const hours = [];
    for (let i = 0; i < b.duration; i++) {
      const h = parseInt(b.startHour) + i;
      hours.push(String(h).padStart(2,'0') + ':00');
    }

    // Check 1: Local check từ bookings đã load
    const conflicting = hours.filter(hour =>
      bookings.some(existing =>
        existing.date === b.date &&
        existing.court === b.court &&
        existing.status !== 'cancelled' &&
        (() => {
          const start = parseInt(existing.startHour);
          for (let i = 0; i < existing.duration; i++) {
            if (String(start + i).padStart(2,'0') + ':00' === hour) return true;
          }
          return false;
        })()
      )
    );

    if (conflicting.length > 0) {
      showNotification(`❌ ${b.court} — giờ ${conflicting.join(', ')} vừa được đặt bởi người khác. Vui lòng chọn lại.`, 'error');
      buildGrid();
      return true;
    }

    // Check 2: Server-side check qua GAS (đảm bảo ko bị race condition)
    try {
      const params = new URLSearchParams({ action:'checkSlot', date:b.date, court:b.court, hours:hours.join(',') });
      const res = await fetch('/api/sheet?' + params.toString());
      const data = await res.json();
      if (data.available === false) {
        const serverConflicts = data.conflicts || hours;
        showNotification(`❌ ${b.court} — giờ ${serverConflicts.join(', ')} đã bị đặt. Vui lòng chọn lại.`, 'error');
        await loadBookingsFromSheet();
        buildGrid();
        return true;
      }
    } catch(e) {
      console.warn('[checkSlot] server check error:', e.message);
      // fail-open nếu server lỗi
    }
  }
  return false;
}

async function confirmBooking() {
  _isConfirming = true;
  // Prevent double submit
  const confirmBtn  = document.getElementById('btnConfirmPayment');
  const confirmText = document.getElementById('btnConfirmText');
  if (confirmBtn && confirmBtn.disabled) return;

  // Helper: restore button khi có lỗi
  function restoreBtn() {
    if (confirmBtn)  { confirmBtn.disabled = false; confirmBtn.style.opacity='1'; confirmBtn.style.pointerEvents='auto'; }
    if (confirmText) { confirmText.textContent = 'Xác nhận đặt sân →'; }
  }

  if (confirmBtn)  { confirmBtn.disabled = true; confirmBtn.style.opacity='0.6'; }
  if (confirmText) { confirmText.textContent = '⏳ Đang xử lý...'; }

  // Auto-restore sau 15 giây phòng trường hợp bị treo
  const safetyTimer = setTimeout(restoreBtn, 15000);

  const name = document.getElementById('inputName').value.trim();
  const phone = document.getElementById('inputPhone').value.trim();
  const note = document.getElementById('inputNote').value.trim();
  const email = '';

  if (!name) { clearTimeout(safetyTimer); restoreBtn(); alert('Vui lòng nhập họ tên.'); return; }
  if (!phone || !/^0\d{9}$/.test(phone.replace(/\s/g,''))) { clearTimeout(safetyTimer); restoreBtn(); alert('Vui lòng nhập số điện thoại hợp lệ (10 số, bắt đầu bằng 0).'); return; }

  // Validate đặt trước tối thiểu 30 phút (chỉ áp dụng cho Black / guest)
  // Silver trở lên + Admin: được đặt sát giờ
  const now        = new Date();
  const todayStr   = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
  const canBookLastMinute = currentMember && ['silver','gold','diamond'].includes(currentMember.tier);
  if (!canBookLastMinute && selectedDate === todayStr && selectedSlots.length > 0) {
    const earliestHour = Math.min(...selectedSlots.map(s => parseInt(s.hour)));
    const deadlineMs   = new Date(`${selectedDate}T${String(earliestHour).padStart(2,'0')}:00:00`).getTime();
    if (Date.now() > deadlineMs - 30 * 60 * 1000) {
      clearTimeout(safetyTimer); restoreBtn();
      alert('⚠️ Vui lòng đặt sân trước ít nhất 30 phút.\n💡 Hội viên Silver trở lên được đặt sát giờ!\nLiên hệ quản lý nếu cần đặt gấp: 0889398931');
      return;
    }
  }
  if (selectedPlayers < 2 || selectedPlayers > 4) { clearTimeout(safetyTimer); restoreBtn(); alert('Vui lòng chọn số người (2–4).'); return; }

  const byCourt = {};
  selectedSlots.forEach(s => {
    const key = s.court + '|' + s.date;
    if (!byCourt[key]) byCourt[key] = { court: s.court, date: s.date, hours: [] };
    byCourt[key].hours.push(s.hour);
  });

  const newBookings = [];
  Object.values(byCourt).forEach(group => {
    group.hours.sort();
    const subtotal = calcTotalForCourtHours(group.hours);
    const racketFee = selectedRackets * PRICE_RACKET * group.hours.length;
    const booking = {
      id: genId(),
      name, phone, email,
      note: note + (currentMember ? ' [MBR:' + (currentMember.tier||'black').toUpperCase() + ']' : ''),
      date: group.date,
      court: group.court,
      startHour: group.hours[0],
      duration: group.hours.length,
      players: selectedPlayers,
      rackets: selectedRackets,
      courtTotal: subtotal,
      racketTotal: racketFee,
      total: subtotal + racketFee,
      status: 'pending',
      payment: selectedPayment || 'cash'
    };
    newBookings.push(booking);
  });

  // ── Race condition check: verify slot chưa bị chiếm ──
  // CRITICAL: check TRƯỚC khi push vào bookings[] để tránh tự conflict với chính mình
  const conflictFound = await checkSlotAvailability(newBookings);
  if (conflictFound) { _isConfirming = false; clearTimeout(safetyTimer); restoreBtn(); return; } // hàm đã show notification

  // Chỉ push vào local bookings[] SAU KHI đã verify không conflict
  newBookings.forEach(b => bookings.push(b));

  // Gửi lên Google Sheet (bất đồng bộ, không chặn UI)
  // Apply tier discount theo tier HIỆN TẠI — KHÔNG thăng bậc ở đây
  // Membership spending chỉ tăng khi admin CONFIRM (GAS handleUpdateStatus xử lý)
  if (currentMember && currentMember.tier) {
    const tierDisc = getTierDiscount();
    if (tierDisc > 0) {
      newBookings.forEach(b => {
        const disc = Math.round(b.total * tierDisc / 100);
        b.total = b.total - disc;
        b.note = b.note + ' | Tier ' + (currentMember.tier||'').toUpperCase() + ' -' + tierDisc + '%: -' + formatMoney(disc);
      });
    }
  }
  newBookings.forEach(b => {
    sendToSheet(b);
    // Telegram: đơn mới
    fetch('/api/notify', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: 'new_order', booking: b })
    }).catch(() => {});
    // Nếu QR → thêm thông báo chuyển khoản vào nhóm Thanh toán
    if (b.payment === 'qr') {
      fetch('/api/notify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 'payment_qr_received', booking: b })
      }).catch(() => {});
    }
  });
  // Spending sẽ được cập nhật bởi Apps Script khi admin confirm

  // Restore button & clear safety timer
  clearTimeout(safetyTimer);
  restoreBtn();

  document.getElementById('paymentModal').classList.remove('show');

  const courtTotal = calcTotal(selectedSlots);
  const totalHours = selectedSlots.length;
  const racketTotal = selectedRackets * PRICE_RACKET * totalHours;
  const grandTotal = courtTotal + racketTotal;
  const perPerson = Math.round(grandTotal / selectedPlayers);
  document.getElementById('successMsg').textContent = 'Quản lý sẽ liên hệ xác nhận qua SĐT.';
  document.getElementById('successDetail').innerHTML = `
    👤 <strong>${name}</strong> &nbsp;·&nbsp; 📞 ${phone}<br>
    📅 ${formatDate(selectedDate)}<br>
    🏟️ ${[...new Set(selectedSlots.map(s=>s.court))].join(', ')}<br>
    ⏱️ ${totalHours} giờ &nbsp;·&nbsp; 👥 ${selectedPlayers} người${selectedRackets > 0 ? ` &nbsp;·&nbsp; 🏓 ${selectedRackets} vợt` : ''}<br>
    💰 Sân: <strong>${formatMoney(courtTotal)}</strong>${racketTotal > 0 ? ` + Vợt: <strong>${formatMoney(racketTotal)}</strong>` : ''}<br>
    💳 Tổng: <strong style="color:var(--green)">${formatMoney(grandTotal)}</strong> &nbsp;·&nbsp; Mỗi người: <strong style="color:var(--yellow)">${formatMoney(perPerson)}</strong><br>
    💳 Thanh toán: <strong>${selectedPayment === 'qr' ? '📲 Đã chuyển khoản QR' : '🏟️ Trả tại sân (giữ 30 phút)'}</strong><br>
    ${currentMember ? '🏅 Hội viên: <strong style="color:' + (TIER_CONFIG[currentMember.tier]?.color||'#8B949E') + '">' + (TIER_CONFIG[currentMember.tier]?.label||'⚫ Black') + '</strong> · Giảm <strong>' + getTierDiscount() + '%</strong><br>' : ''}
    🔔 Trạng thái: <span style="color:var(--yellow)">Chờ xác nhận</span>
  `;

  // Nếu chuyển khoản → hiện "đang chờ xác nhận thanh toán"
  const isQR = selectedPayment === 'qr';
  document.getElementById('successIcon').textContent = isQR ? '⏳' : '✅';
  document.getElementById('successTitle').textContent = isQR ? 'CHỜ XÁC NHẬN THANH TOÁN' : 'ĐẶT SÂN THÀNH CÔNG!';
  document.getElementById('successMsg').textContent = isQR
    ? 'Quản lý sẽ xác nhận sau khi nhận được chuyển khoản.'
    : 'Quản lý sẽ liên hệ xác nhận qua SĐT.';
  _isConfirming = false;
  openSuccessModal();
  clearSelection();
  buildGrid();
}

function closeSuccessModal() {
  clearInterval(window._successTimer);
  window._successTimer = null;
  document.getElementById('successModal').classList.remove('show');
}

function openSuccessModal() {
  document.getElementById('successModal').classList.add('show');
  var n = 30;
  var el = document.getElementById('successCountdown');
  if (el) el.textContent = n;
  clearInterval(window._successTimer);
  window._successTimer = setInterval(function() {
    n--;
    if (el) el.textContent = n;
    if (n <= 0) closeSuccessModal();
  }, 1000);
}

// ========================
// NOTIFICATION
// ========================
function showNotification(msg) {
  const n = document.createElement('div');
  n.className = 'notification';
  n.textContent = msg;
  document.body.appendChild(n);
  setTimeout(() => n.remove(), 3000);
}


// ========================
// PAYMENT
// ========================
let selectedPayment = null;
let pendingBookingData = null;

function goToPayment() {
  const name = document.getElementById('inputName').value.trim();
  const phone = document.getElementById('inputPhone').value.trim();
  const note = document.getElementById('inputNote').value.trim();

  if (!name) { alert('Vui lòng nhập họ tên.'); return; }
  if (!phone || !/^0\d{9}$/.test(phone.replace(/\s/g,''))) {
    alert('Vui lòng nhập số điện thoại hợp lệ (10 số, bắt đầu bằng 0).'); return;
  }

  const totalHours = selectedSlots.length;
  const courtTotal = calcTotal(selectedSlots);
  const racketTotal = selectedRackets * PRICE_RACKET * totalHours;
  const grandTotal = courtTotal + racketTotal;

  // Tính tier discount ngay khi mở payment modal
  const tierDisc   = getTierDiscount(); // % discount
  const discAmount = currentMember && tierDisc > 0 ? Math.round(grandTotal * tierDisc / 100) : 0;
  const finalTotal = grandTotal - discAmount;

  pendingBookingData = { name, phone, note };

  // Render tier discount banner
  const tierBanner = document.getElementById('tierDiscountBanner');
  const tierText   = document.getElementById('tierDiscountText');
  const tierAmt    = document.getElementById('tierDiscountAmount');
  const tierLabel  = document.getElementById('tierDiscountLabel');
  if (tierBanner) {
    if (currentMember && tierDisc > 0) {
      const tierCfg = TIER_CONFIG[currentMember.tier] || TIER_CONFIG.black;
      tierBanner.style.display = '';
      tierBanner.style.background = tierCfg.bg;
      tierBanner.style.borderColor = tierCfg.color + '55';
      if (tierLabel) { tierLabel.textContent = tierCfg.label; tierLabel.style.color = tierCfg.color; }
      if (tierText)  tierText.innerHTML = 'Giảm <strong style="color:' + tierCfg.color + '">' + tierDisc + '%</strong> tự động cho đơn này';
      if (tierAmt)   { tierAmt.textContent = '−' + formatMoney(discAmount); tierAmt.style.color = tierCfg.color; }
    } else {
      tierBanner.style.display = 'none';
    }
  }

  document.getElementById('paymentSummary').innerHTML = `
    <div style="display:flex;justify-content:space-between;font-size:0.85rem;margin-bottom:4px">
      <span style="color:var(--text2)">📅 ${formatDate(selectedDate)}</span>
      <span style="color:var(--text2)">${totalHours} giờ · ${[...new Set(selectedSlots.map(s=>s.court))].join(', ')}</span>
    </div>
    ${discAmount > 0 ? `
    <div style="display:flex;justify-content:space-between;font-size:0.85rem;margin-bottom:4px">
      <span style="color:var(--text2)">Giá gốc</span>
      <span style="color:var(--text2);text-decoration:line-through">${formatMoney(grandTotal)}</span>
    </div>` : ''}
    <div style="display:flex;justify-content:space-between;align-items:center">
      <span style="color:var(--text2)">💰 Tổng cần thanh toán</span>
      <span style="font-family:'DM Sans',sans-serif;font-size:1.8rem;font-weight:700;color:var(--green)">${formatMoney(finalTotal)}</span>
    </div>
  `;

  closeModal();
  selectedPayment = null;
  document.getElementById('qrContent').style.display = 'none';
  document.getElementById('cashContent').style.display = 'none';
  document.getElementById('btnQR').style.borderColor = 'var(--border)';
  document.getElementById('btnCash').style.borderColor = 'var(--border)';
  document.getElementById('btnConfirmPayment').style.opacity = '0.4';
  document.getElementById('btnConfirmPayment').style.pointerEvents = 'none';
  document.getElementById('paymentModal').classList.add('show');
}

function selectPayment(type) {
  selectedPayment = type;
  document.getElementById('btnQR').style.borderColor = type === 'qr' ? 'var(--green)' : 'var(--border)';
  document.getElementById('btnCash').style.borderColor = type === 'cash' ? 'var(--yellow)' : 'var(--border)';
  document.getElementById('qrContent').style.display = type === 'qr' ? 'block' : 'none';
  document.getElementById('cashContent').style.display = type === 'cash' ? 'block' : 'none';

  if (type === 'qr') {
    // Tạo QR chuyển khoản MSB VietQR — dùng finalTotal đã trừ discount
    const totalHours = selectedSlots.length;
    const courtTotal = calcTotal(selectedSlots);
    const racketTotal = selectedRackets * PRICE_RACKET * totalHours;
    const grandTotal = courtTotal + racketTotal;
    const tierDisc   = getTierDiscount();
    const discAmount = currentMember && tierDisc > 0 ? Math.round(grandTotal * tierDisc / 100) : 0;
    const finalTotal = grandTotal - discAmount;
    const bookId = 'BK' + String(bookings.length + 1).padStart(3, '0');
    const courts = [...new Set(selectedSlots.map(s => s.court.replace('Sân ','S')))].join('');
    const note = encodeURIComponent('DatSan ' + bookId + ' ' + courts + ' ' + selectedSlots[0].hour);
    const qrUrl = `https://img.vietqr.io/image/MSB-2320092005-compact2.png?amount=${finalTotal}&addInfo=${note}&accountName=TRAN%20HOANG%20GIA%20KHANH`;
    document.getElementById('qrImg').src = qrUrl;
    document.getElementById('qrNote').textContent = 'DatSan ' + bookId + ' ' + courts + ' ' + selectedSlots[0].hour;
  }

  document.getElementById('btnConfirmPayment').style.opacity = '1';
  document.getElementById('btnConfirmPayment').style.pointerEvents = 'auto';
}

function closePaymentModal() {
  document.getElementById('paymentModal').classList.remove('show');
  document.getElementById('bookingModal').classList.add('show');
}


// ========================
// LOAD CONFIG từ Sheet (sync với V9 Super Admin)
// ========================
async function loadConfig() {
  try {
    const res = await fetch('/api/sheet?action=readConfig');
    if (!res.ok) return;
    const cfg = await res.json();
    if (!cfg || cfg.error || !cfg.priceDay) return;

    // Áp dụng giá
    if (cfg.priceDay)    PRICE_DAY    = Number(cfg.priceDay);
    if (cfg.priceNight)  PRICE_NIGHT  = Number(cfg.priceNight);
    if (cfg.priceRacket) PRICE_RACKET = Number(cfg.priceRacket);

    // Áp dụng sân active
    if (cfg.activeCourts && Array.isArray(cfg.activeCourts) && cfg.activeCourts.length > 0) {
      COURTS = cfg.activeCourts;
    }

    // Áp dụng giờ
    if (cfg.hourOpen !== undefined && cfg.hourClose !== undefined) {
      const hours = [];
      for (let h = Number(cfg.hourOpen); h < Number(cfg.hourClose); h++) {
        hours.push(String(h).padStart(2,'0') + ':00');
      }
      HOURS = hours;
    }
    if (cfg.hourNight !== undefined) window._nightHour = Number(cfg.hourNight);

    console.log('[V10 Config] Applied:', cfg);
    applyUiConfig(cfg);
  } catch(e) {
    console.warn('[V10 Config] Error:', e.message);
  }
}

// ========================
// INIT
// ========================
document.addEventListener('DOMContentLoaded', () => {
  // Đảm bảo tất cả modal đóng khi load (tránh cache stuck)
  ['bookingModal','paymentModal','successModal','memberModal'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.remove('show');
  });

  // Hiện grid trống ngay lập tức
  buildDateStrip();
  buildGrid();

  // Load config + bookings song song
  Promise.all([
    loadConfig(),
    loadBookingsFromSheet()
  ]).then(() => {
    // Rebuild grid sau khi có đủ data
    buildDateStrip();
    buildGrid();
  });

  // Refresh grid mỗi phút — cập nhật slot đã qua giờ thành màu xám
  setInterval(() => buildGrid(), 60 * 1000);

  // Polling sheet mỗi 30s để cập nhật slot realtime (tránh user thấy trống rồi conflict khi đặt)
  setInterval(async () => {
    try {
      await loadBookingsFromSheet(selectedDate);
    } catch(e) {}
  }, 30 * 1000);

  // Polling membership mỗi 60s — cập nhật tier/spending realtime sau khi admin confirm đơn
  setInterval(async () => {
    if (!currentMember || !currentMember.phone) return;
    try {
      const res = await fetch('/api/sheet?action=getMember&phone=' + encodeURIComponent(currentMember.phone));
      const data = await res.json();
      if (data.found && data.member) {
        const m = data.member;
        // Chỉ update nếu có thay đổi thực sự (tier hoặc spending)
        if (m.tier !== currentMember.tier || m.monthlySpent !== currentMember.monthlySpent) {
          console.log('[Membership] Tier updated:', currentMember.tier, '->', m.tier, '| Spent:', m.monthlySpent);
          onMemberLoggedIn(m, true);
          renderMemberDashboard(m);
          renderTierDiscountBanner();
        }
      }
    } catch(e) {}
  }, 60 * 1000);

  // Khi user quay lại tab → reload ngay
  document.addEventListener('visibilitychange', async () => {
    if (document.visibilityState === 'visible') {
      try { await loadBookingsFromSheet(selectedDate); } catch(e) {}
    }
  });

});

