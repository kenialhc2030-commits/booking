// ── ON LOGGED IN ──────────────────────────────
function onMemberLoggedIn(member, save) {
  // Normalize: GAS cũ có thể không trả tier → default black
  if (!member.tier || !TIER_CONFIG[member.tier]) member.tier = 'black';
  if (member.tierDiscount === undefined) member.tierDiscount = TIER_CONFIG[member.tier].discount;
  currentMember = member;
  if (save) localStorage.setItem('memberSession_v2', JSON.stringify({ ...member, _savedAt: Date.now() }));
  const tierCfg = TIER_CONFIG[member.tier] || TIER_CONFIG.black;
  const btn = document.getElementById('memberNavBtn');
  if (btn) btn.textContent = tierCfg.label.split(' ')[0] + ' ' + member.name.split(' ').pop();
  const badge = document.getElementById('memberBadge');
  if (badge) {
    document.getElementById('memberBadgeName').textContent = member.name;
    document.getElementById('memberBadgePoints').textContent = tierCfg.label;
    badge.style.color = tierCfg.color;
    badge.style.background = tierCfg.bg;
    badge.classList.add('visible');
  }
  autoFillFromMember(member);
}

function autoFillFromMember(member) {
  const nameEl  = document.getElementById('inputName');
  const phoneEl = document.getElementById('inputPhone');
  if (nameEl  && !nameEl.value)  nameEl.value  = member.name;
  if (phoneEl && !phoneEl.value) phoneEl.value = member.phone;
  const banner = document.getElementById('memberAutofillBanner');
  if (banner) banner.style.display = 'flex';
}
function clearMemberAutofill() {
  document.getElementById('inputName').value  = '';
  document.getElementById('inputPhone').value = '';
  document.getElementById('memberAutofillBanner').style.display = 'none';
}

// ── DASHBOARD ────────────────────────────────
function renderMemberDashboard(member) {
  document.getElementById('mDashName').textContent  = member.name;
  document.getElementById('mDashPhone').textContent = member.phone;
  const tier    = member.tier || 'black';
  const tierCfg = TIER_CONFIG[tier] || TIER_CONFIG.black;
  const monthly = member.monthlySpent || 0;

  // Tiers theo thứ tự
  const tiers = ['black','silver','gold','diamond'];
  const mins  = { black:0, silver:500000, gold:1000000, diamond:2000000 };
  const curIdx = tiers.indexOf(tier);
  const nextTierName = tiers[Math.min(curIdx+1, 3)];
  const nextMin = mins[nextTierName];
  const progress = tier === 'diamond' ? 100 : Math.min(100, Math.round(monthly / nextMin * 100));
  const needed = Math.max(0, nextMin - monthly);

  // Tier badge
  const tierBadgeEl = document.getElementById('mDashTierBadge');
  if (tierBadgeEl) {
    tierBadgeEl.textContent = tierCfg.label;
    tierBadgeEl.style.color = tierCfg.color;
    tierBadgeEl.style.background = tierCfg.bg;
    tierBadgeEl.style.border = '1px solid ' + tierCfg.color + '44';
  }
  // Spent this month
  const spentEl = document.getElementById('mDashSpent');
  if (spentEl) spentEl.textContent = formatMoney(monthly);
  // Progress bar
  const fillEl = document.getElementById('mDashPointsFill');
  if (fillEl) { fillEl.style.width = progress + '%'; fillEl.style.background = tierCfg.color; }
  // Needed + next tier
  const neededEl = document.getElementById('mDashPointsNeeded');
  const nextEl   = document.getElementById('mDashNextTier');
  if (tier === 'diamond') {
    if (neededEl) neededEl.textContent = '';
    const neededRow = neededEl && neededEl.closest('div');
    if (neededRow) neededRow.style.display = 'none';
  } else {
    if (neededEl) neededEl.textContent = formatMoney(needed);
    if (nextEl)   nextEl.textContent = TIER_CONFIG[nextTierName].label;
  }
  // Discount
  const discEl = document.getElementById('mDashDiscount');
  if (discEl) discEl.textContent = 'Giảm ' + tierCfg.discount + '% tự động';
  // Highlight active tier in grid
  const tierOrder = ['black','silver','gold','diamond'];
  document.querySelectorAll('#mState_dashboard .tier-grid-item').forEach((el, i) => {
    el.style.opacity = i <= tierOrder.indexOf(tier) ? '1' : '0.4';
  });
}

// ── VOUCHER ───────────────────────────────────
// Hiển thị tier discount trong payment modal
function renderTierDiscountBanner() {
  const banner = document.getElementById('tierDiscountBanner');
  const textEl = document.getElementById('tierDiscountText');
  if (!banner || !textEl) return;
  if (!currentMember || !currentMember.tier) { banner.style.display = 'none'; return; }
  const tierCfg = TIER_CONFIG[currentMember.tier] || TIER_CONFIG.black;
  const disc    = getTierDiscount();
  if (disc <= 0) { banner.style.display = 'none'; return; }
  banner.style.display  = '';
  banner.style.background = tierCfg.bg;
  banner.style.border   = '1px solid ' + tierCfg.color + '55';
  textEl.innerHTML = tierCfg.label.split(' ')[0] + ' <strong style="color:' + tierCfg.color + '">' + tierCfg.label.split(' ').slice(1).join(' ') + '</strong> · Giảm tự động <strong style="color:' + tierCfg.color + '">' + disc + '%</strong> cho đơn này';
}

// addPointsForBooking removed — tier system handles discount automatically

// ── Hook openModal: autofill + tier discount ─
(function() {
  var _orig = openModal;
  openModal = function() {
    _orig();
    setTimeout(() => {
      if (currentMember) autoFillFromMember(currentMember);
      renderTierDiscountBanner();
    }, 50);
  };
})();

// ── UI CONFIG FROM SHEET ──────────────────────
function applyUiConfig(cfg) {
  if (!cfg) return;
  const g = id => document.getElementById(id);

  // Tên sân → split: phần cuối màu xanh
  if (cfg.uiVenueName) {
    const parts  = cfg.uiVenueName.trim().split(' ');
    const accent = parts.pop();
    const main   = parts.join(' ');
    if (g('heroTitle'))  g('heroTitle').childNodes[0].textContent = (main ? main + ' ' : '');
    if (g('heroAccent')) g('heroAccent').textContent = accent;
  }

  // Subtitle: địa chỉ · số sân · giờ
  const s = g('heroSubtitle');
  if (s) {
    const addr   = cfg.uiVenueAddress    || 'Nhơn Trạch, Đồng Nai';
    const courts = cfg.uiVenueCourtCount || '5';
    const open   = cfg.hourOpen  !== undefined ? String(cfg.hourOpen).padStart(2,'0')  + ':00' : '06:00';
    const close  = cfg.hourClose !== undefined ? String(cfg.hourClose).padStart(2,'0') + ':00' : '22:00';
    s.innerHTML  = addr + ' &nbsp;·&nbsp; ' + courts + ' sân có mái che &nbsp;·&nbsp; ' + open + ' – ' + close;
  }

  // Số điện thoại trên nav
  if (cfg.uiVenuePhone) {
    const telLink = document.querySelector('a[href^="tel:"]');
    if (telLink) {
      telLink.href        = 'tel:' + cfg.uiVenuePhone.replace(/\s/g,'');
      telLink.textContent = '📞 ' + cfg.uiVenuePhone;
    }
  }

  // Tab title
  if (cfg.uiPageTitle) document.title = cfg.uiPageTitle;
}

</script>

