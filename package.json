// MEMBERSHIP SYSTEM v2 — email+password auth
// ════════════════════════════════════════════════

let currentMember   = null;
let _isConfirming   = false; // guard: tránh polling overwrite booking khi đang confirm
// selectedVoucher removed — using tier discount
let _mRegData       = {};   // tạm lưu khi đăng ký
