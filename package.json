// ── REGISTER step 1: gửi OTP ─────────────────
async function sendRegisterOtp() {
  const name  = document.getElementById('mRegName').value.trim();
  const phone = document.getElementById('mRegPhone').value.replace(/\s/g,'');
  const email = document.getElementById('mRegEmail').value.trim();
  setErr('mRegError', '');
  if (!name)  { setErr('mRegError','Vui lòng nhập họ tên'); return; }
  if (!/^0\d{9}$/.test(phone)) { setErr('mRegError','Số điện thoại không hợp lệ'); return; }
  if (!email || !email.includes('@')) { setErr('mRegError','Email không hợp lệ'); return; }

  _mRegData = { name, phone, email };
  const sendBtn = document.querySelector('#mState_register button[onclick="sendRegisterOtp()"]');
  if (sendBtn) { sendBtn.disabled = true; sendBtn.textContent = '⏳ Đang gửi...'; }
  try {
    const data = await apiGet('action=memberOtp&phone=' + encodeURIComponent(phone) + '&method=email&email=' + encodeURIComponent(email) + '&purpose=register');
    if (sendBtn) { sendBtn.disabled = false; sendBtn.textContent = 'Gửi mã OTP →'; }
    if (data.error) {
      setErr('mRegError', data.error + ' (Nếu lỗi liên tục, liên hệ quản lý)');
      return;
    }
    document.getElementById('mRegOtpHint').textContent = 'Mã OTP đã gửi đến ' + email + '. Kiểm tra cả hộp thư Spam.';
    showMemberState('regOtp');
  } catch(e) {
    if (sendBtn) { sendBtn.disabled = false; sendBtn.textContent = 'Gửi mã OTP →'; }
    setErr('mRegError','Lỗi kết nối. Vui lòng thử lại.');
  }
}

// ── REGISTER step 2: xác nhận OTP + set pass ─
async function doRegister() {
  const otp   = document.getElementById('mRegOtp').value.trim();
  const pass1 = document.getElementById('mRegPass1').value;
  const pass2 = document.getElementById('mRegPass2').value;
  setErr('mRegOtpError','');
  if (!otp || !/^\d{6}$/.test(otp)) { setErr('mRegOtpError','Nhập mã OTP 6 chữ số'); return; }
  if (!/^\d{6}$/.test(pass1))   { setErr('mRegOtpError','Mật khẩu phải là 6 chữ số'); return; }
  if (pass1 !== pass2)           { setErr('mRegOtpError','Mật khẩu nhập lại không khớp'); return; }
  try {
    const data = await apiGet(
      'action=registerMember'
      + '&name='  + encodeURIComponent(_mRegData.name)
      + '&phone=' + encodeURIComponent(_mRegData.phone)
      + '&email=' + encodeURIComponent(_mRegData.email)
      + '&otp='   + otp
      + '&passHash=' + hashPass(pass1)
    );
    if (!data.success) { setErr('mRegOtpError', data.error || 'Đăng ký thất bại'); return; }
    onMemberLoggedIn(data.member, true);
    showMemberState('dashboard');
    renderMemberDashboard(data.member);
  } catch(e) { setErr('mRegOtpError','Lỗi kết nối'); }
}

// ── LOGIN ─────────────────────────────────────
async function doLogin() {
  const phone = document.getElementById('mLoginPhone').value.replace(/\s/g,'');
  const pass  = document.getElementById('mLoginPass').value;
  setErr('mLoginError','');
  if (!/^0\d{9}$/.test(phone)) { setErr('mLoginError','Số điện thoại không hợp lệ'); return; }
  if (!/^\d{6}$/.test(pass))   { setErr('mLoginError','Mật khẩu phải là 6 chữ số'); return; }
  try {
    // Thử cả với và không có số 0 đầu để match mọi cách lưu trong Sheet
    const data = await apiGet(
      'action=loginMember&phone=' + encodeURIComponent(phone) + '&passHash=' + hashPass(pass)
    );
    if (!data.success) {
      // Nếu báo "chưa đăng ký" nhưng user vừa tạo tài khoản → có thể phone lưu thiếu số 0
      // Thử lại với phone không có 0 đầu
      if (data.error && data.error.includes('chưa đăng ký')) {
        const phoneAlt = phone.startsWith('0') ? phone.slice(1) : '0' + phone;
        const data2 = await apiGet(
          'action=loginMember&phone=' + encodeURIComponent(phoneAlt) + '&passHash=' + hashPass(pass)
        );
        if (data2.success) {
          onMemberLoggedIn(data2.member, true);
          showMemberState('dashboard');
          renderMemberDashboard(data2.member);
          return;
        }
      }
      setErr('mLoginError', data.error || 'Sai số điện thoại hoặc mật khẩu'); return;
    }
    onMemberLoggedIn(data.member, true);
    showMemberState('dashboard');
    renderMemberDashboard(data.member);
  } catch(e) { setErr('mLoginError','Lỗi kết nối'); }
}

// ── FORGOT PASSWORD ───────────────────────────
async function sendForgotOtp() {
  _mForgotPhone = document.getElementById('mForgotPhone').value.replace(/\s/g,'');
