let _mForgotEmail   = '';

// ── Helpers ──────────────────────────────────
function togglePassVis(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  el.type = el.type === 'password' ? 'text' : 'password';
  btn.textContent = el.type === 'password' ? '👁' : '🙈';
}
function setErr(id, msg) {
  const el = document.getElementById(id);
  if (el) el.textContent = msg || '';
}
function apiGet(qs) {
  return fetch('/api/sheet?' + qs).then(r => r.json());
}
function hashPass(pass) {
  // Simple deterministic hash — đủ cho 6-digit PIN (không dùng cho secret thực sự)
  let h = 0;
  for (let i = 0; i < pass.length; i++) h = Math.imul(31, h) + pass.charCodeAt(i) | 0;
  return (h >>> 0).toString(16).padStart(8, '0');
}

// ── Session ───────────────────────────────────
(function restoreMemberSession() {
  try {
    const saved = localStorage.getItem('memberSession_v2');
    if (!saved) return;
    const m = JSON.parse(saved);
    if (!m || !m.phone) return;
    if (m._savedAt && Date.now() - m._savedAt > 7 * 24 * 60 * 60 * 1000) {
      localStorage.removeItem('memberSession_v2'); return;  // 7 ngày
    }
    currentMember = m;
    onMemberLoggedIn(m, false);
  } catch(e) {}
})();

