<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Đặt Sân Pickleball</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #2ECC71;
    --green-dark: #27AE60;
    --green-light: #ABEBC6;
    --red: #E74C3C;
    --yellow: #F39C12;
    --bg: #0D1117;
    --bg2: #161B22;
    --bg3: #21262D;
    --border: #30363D;
    --text: #E6EDF3;
    --text2: #8B949E;
    --white: #ffffff;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  /* NAV */
  nav {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    font-style: italic;
    letter-spacing: 0.5px;
    color: var(--green);
    text-transform: uppercase;
  }

  .logo span { color: var(--text); }

  .nav-tabs {
    display: flex;
    gap: 0;
    background: var(--bg3);
    border-radius: 8px;
    padding: 4px;
  }

  .nav-tab {
    padding: 12px 20px;
    min-height: 44px;
    border: none;
    background: transparent;
    color: var(--text2);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .nav-tab.active {
    background: var(--green);
    color: #000;
  }

  /* PAGES */
  .page { display: none; padding: 2rem; max-width: 1200px; margin: 0 auto; }
  .page.active { display: block; }

  /* HERO */
  .hero {
    text-align: center;
    padding: 3.5rem 0 2.5rem;
  }

  .hero h1 {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 4rem;
    font-weight: 900;
    letter-spacing: 1px;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    text-shadow: 0 2px 24px rgba(46,204,113,0.2);
    text-transform: uppercase;
  }

  .hero h1 span { color: var(--green); }

  .hero p {
    color: var(--text2);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  /* DATE SELECTOR */
  .date-strip {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
    scrollbar-width: none;
  }

  .date-strip::-webkit-scrollbar { display: none; }

  .date-btn {
    flex-shrink: 0;
    padding: 10px 16px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    min-width: 70px;
  }

  .date-btn .day { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
  .date-btn .num { font-size: 1.4rem; font-weight: 600; color: var(--text); }
  .date-btn:hover { border-color: var(--green); }
  .date-btn.active { background: var(--green); border-color: var(--green); }
  .date-btn.active .day, .date-btn.active .num { color: #000; }

  /* GRID */
  .grid-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .grid-title {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text2);
  }

  .legend {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--text2);
  }

  .legend-item { display: flex; align-items: center; gap: 6px; }
  .legend-dot {
    width: 10px; height: 10px;
    border-radius: 3px;
  }

  .court-grid {
    overflow-x: auto;
  }

  .court-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
  }

  .court-table th {
    padding: 12px 8px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text2);
    text-align: center;
    border-bottom: 1px solid var(--border);
  }

  .court-table th:first-child {
    text-align: left;
    padding-left: 1rem;
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  .court-table td {
    padding: 5px 4px;
    text-align: center;
    vertical-align: middle;
  }

  .court-table td:first-child {
    padding-left: 1rem;
    font-size: 0.8rem;
    color: var(--text2);
    text-align: left;
    white-space: nowrap;
    font-weight: 500;
  }

  .slot {
    width: 100%;
    height: 52px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    transition: all 0.15s;
    position: relative;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
  }

  .slot.available {
    background: rgba(46, 204, 113, 0.15);
    color: var(--green);
    border: 1px solid rgba(46, 204, 113, 0.3);
  }

  .slot.available:hover {
    background: var(--green);
    color: #000;
    transform: scale(1.05);
  }

  .slot.past {
    background: rgba(100, 100, 100, 0.08);
    color: rgba(150, 150, 150, 0.5);
    border: 1px solid rgba(150, 150, 150, 0.15);
    cursor: not-allowed;
    text-decoration: line-through;
  }
  .booked {
    background: rgba(231, 76, 60, 0.15);
    color: var(--red);
    border: 1px solid rgba(231, 76, 60, 0.2);
    cursor: not-allowed;
    font-size: 0.65rem;
  }

  .slot.selected {
    background: var(--yellow);
    color: #000;
    border: 1px solid var(--yellow);
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(243,156,18,0.4); }
    50% { box-shadow: 0 0 0 4px rgba(243,156,18,0); }
  }

  /* BOOKING PANEL */
  .booking-panel {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--bg2);
    border-top: 1px solid var(--border);
    padding: 1rem 2rem;
    display: none;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    z-index: 50;
    flex-wrap: wrap;
  }

  .booking-panel.show { display: flex; }

  /* Tránh bị che slot khi booking-panel xuất hiện */
  body.panel-open { padding-bottom: 130px; }
  @media (max-width: 600px) { body.panel-open { padding-bottom: 160px; } }

  .booking-summary { font-size: 0.9rem; }
  .booking-summary strong { color: var(--green); font-size: 1.2rem; font-family: 'Be Vietnam Pro', sans-serif; font-weight: 700; letter-spacing: 0.3px; }

  .btn {
    padding: 12px 24px;
    min-height: 44px;
    border-radius: 10px;
    border: none;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.2px;
  }
  .btn:active {
    transform: scale(0.97);
    opacity: 0.85;
  }
  .slot:active:not(:disabled) {
    transform: scale(0.93);
  }

  .btn-primary {
    background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
    color: #000;
    box-shadow: 0 4px 18px rgba(46,204,113,0.3);
  }
  .btn-primary:hover {
    box-shadow: 0 6px 24px rgba(46,204,113,0.45);
    transform: translateY(-1px);
    background: linear-gradient(135deg, #35D679 0%, #2ECC71 100%);
  }
  .btn-primary:active { transform: translateY(0); }
  .btn-danger { background: transparent; color: var(--red); border: 1px solid var(--red); }
  .btn-danger:hover { background: var(--red); color: white; }
  .btn-secondary { background: var(--bg3); color: var(--text); border: 1px solid var(--border); }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(4px);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .modal-overlay.show { display: flex; }

  .modal {
    background: linear-gradient(145deg, #0f1923 0%, #141d27 100%);
    border: 1px solid rgba(46,204,113,0.12);
    box-shadow: 0 0 0 1px rgba(46,204,113,0.06), 0 32px 64px rgba(0,0,0,0.75), 0 0 60px rgba(46,204,113,0.04);
    border-radius: 20px;
    padding: 2rem;
    width: 100%;
    max-width: 480px;
    animation: slideUp 0.3s cubic-bezier(0.34,1.56,0.64,1);
    position: relative;
    overflow: hidden;
  }
  .modal::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 180px; height: 180px;
    background: radial-gradient(circle, rgba(46,204,113,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  @keyframes slideUp {
    from { transform: translateY(24px) scale(0.97); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }

  .modal h2 {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: 0.5px;
    line-height: 1.05;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
  }

  .modal-info {
    background: var(--bg3);
    border-radius: 10px;
    padding: 1rem;
    margin: 1rem 0;
    font-size: 0.85rem;
    color: var(--text2);
    line-height: 1.8;
  }

  .modal-info strong { color: var(--text); }

  .form-group { margin-bottom: 1rem; }

  .form-group label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(139,148,158,0.85);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-family: 'Inter', sans-serif;
  }

  .form-group input {
    width: 100%;
    padding: 10px 14px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .form-group input:focus { border-color: var(--green); }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .modal-actions .btn { flex: 1; }

  /* PRICE TAG */
  .price-tag {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--green);
  }

  /* ADMIN PAGE */
  .admin-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .admin-header h1 {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 2.2rem;
    font-weight: 900;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .stat-card .label {
    font-size: 0.75rem;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }

  .stat-card .value {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: 0px;
  }

  .stat-card.green .value { color: var(--green); }
  .stat-card.red .value { color: var(--red); }
  .stat-card.yellow .value { color: var(--yellow); }

  /* TABLE */
  .bookings-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg2);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .bookings-table th {
    padding: 12px 16px;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: var(--bg3);
    border-bottom: 1px solid var(--border);
  }

  .bookings-table td {
    padding: 12px 16px;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .bookings-table tr:last-child td { border-bottom: none; }

  .bookings-table tr:hover td { background: rgba(255,255,255,0.02); }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .badge-pending { background: rgba(243,156,18,0.2); color: var(--yellow); }
  .badge-confirmed { background: rgba(46,204,113,0.2); color: var(--green); }
  .badge-cancelled { background: rgba(231,76,60,0.2); color: var(--red); }

  .action-btns { display: flex; gap: 6px; }

  .btn-sm {
    padding: 5px 12px;
    border-radius: 6px;
    border: none;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn-confirm { background: rgba(46,204,113,0.2); color: var(--green); }
  .btn-confirm:hover { background: var(--green); color: #000; }
  .btn-cancel { background: rgba(231,76,60,0.2); color: var(--red); }
  .btn-cancel:hover { background: var(--red); color: white; }

  /* SUCCESS */
  .success-screen {
    display: none;
    text-align: center;
    padding: 3rem 1rem;
  }

  .success-screen.show { display: block; }

  .success-icon {
    width: 80px; height: 80px;
    background: rgba(46,204,113,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    font-size: 2rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--text2);
  }

  .filter-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text2);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn.active { background: var(--green); color: #000; border-color: var(--green); }

  .player-btn {
    width: 52px; height: 52px;
    border-radius: 12px;
    border: 2px solid var(--border);
    background: var(--bg3);
    color: var(--text2);
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .player-btn:hover { border-color: var(--green); color: var(--green); }

  .player-btn.active {
    background: rgba(46,204,113,0.2);
    border-color: var(--green);
    color: var(--green);
  }

  .modal { max-height: 90vh; overflow-y: auto; }

  .notification {
    position: fixed;
    top: 80px;
    right: 1rem;
    background: var(--bg2);
    border: 1px solid var(--green);
    border-radius: 10px;
    padding: 1rem 1.5rem;
    font-size: 0.875rem;
    z-index: 300;
    animation: fadeIn 0.3s ease;
    max-width: 300px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @media (max-width: 768px) {
    .modal { padding: 1.5rem; }
    .super-admin-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .hero h1 { font-size: 2.4rem; letter-spacing: 0.5px; }
    .hero p { font-size: 0.85rem; }
    nav { padding: 0 0.75rem; }
    .page { padding: 0.75rem; }
    .logo { font-size: 1.1rem; letter-spacing: 1px; }
    .nav-tab { padding: 10px 10px; font-size: 0.78rem; min-height: 44px; }
    .slot { height: 46px; font-size: 0.7rem; }
    .court-table th { font-size: 0.65rem; padding: 6px 3px; }
    .court-table td { padding: 3px 2px; }
    .modal { border-radius: 12px; padding: 1.25rem; }
    .modal h2 { font-size: 1.6rem; }
    .btn { padding: 12px 16px; font-size: 0.85rem; }
    .booking-panel { padding: 0.75rem 1rem; flex-direction: column; gap: 0.5rem; }
    .date-strip { gap: 4px; padding: 0.75rem 0; }
    .date-btn { min-width: 52px; padding: 8px 6px; }
  }

/* ══════════════════════════════════════════
   MEMBERSHIP MODAL — Redesign 2026
   Aesthetic: Sport-dark / Neon accent
   ══════════════════════════════════════════ */

/* Modal base override for membership */
#memberModal .modal {
  background: linear-gradient(145deg, #0f1923 0%, #141d27 100%);
  border: 1px solid rgba(46,204,113,0.15);
  box-shadow: 0 0 0 1px rgba(46,204,113,0.08), 0 32px 64px rgba(0,0,0,0.7), 0 0 80px rgba(46,204,113,0.05);
  border-radius: 20px;
  padding: 1.75rem;
  position: relative;
  overflow: hidden;
}
#memberModal .modal::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 180px; height: 180px;
  background: radial-gradient(circle, rgba(46,204,113,0.12) 0%, transparent 70%);
  pointer-events: none;
}

/* Titles */
#memberModal h2 {
  font-family: 'Be Vietnam Pro', sans-serif;
  font-size: 1.9rem;
  font-weight: 900;
  letter-spacing: 0.3px;
  color: var(--text);
  line-height: 1.0;
  text-transform: uppercase;
}
#memberModal h2 .icon-label {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

/* Body text */
.member-modal-body { padding: 0.5rem 0; }
#memberModal p {
  color: var(--text2);
  font-size: 0.88rem;
  line-height: 1.6;
}
#memberModal small {
  color: rgba(139,148,158,0.75);
  font-size: 0.78rem;
  display: block;
  margin-top: 0.3rem;
}

/* Divider accent */
.modal-accent-bar {
  height: 2px;
  background: linear-gradient(90deg, var(--green), transparent);
  border-radius: 2px;
  margin: 1rem 0;
  opacity: 0.5;
}

/* ── Form fields ── */
.mfield { margin-bottom: 1rem; }
.mfield label {
  display: block;
  font-size: 0.72rem;
  color: var(--text2);
  margin-bottom: 0.4rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  font-family: 'Inter', sans-serif;
}
.mfield input {
  width: 100%;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  color: var(--text);
  padding: 0.75rem 1rem;
  font-size: 0.95rem;
  box-sizing: border-box;
  font-family: 'Inter', sans-serif;
  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
}
.mfield input:focus {
  outline: none;
  border-color: var(--green);
  background: rgba(46,204,113,0.05);
  box-shadow: 0 0 0 3px rgba(46,204,113,0.12);
}
.mfield input::placeholder { color: rgba(139,148,158,0.5); }

.pass-eye {
  position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%);
  background: none; border: none; color: var(--text2); cursor: pointer;
  font-size: 1rem; padding: 0.2rem; opacity: 0.6; transition: opacity 0.15s;
}
.pass-eye:hover { opacity: 1; }

/* ── Buttons in modal ── */
#memberModal .btn {
  border-radius: 10px;
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 0.9rem;
  letter-spacing: 0.3px;
  transition: all 0.2s;
}
#memberModal .btn-primary {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  color: #000;
  border: none;
  box-shadow: 0 4px 20px rgba(46,204,113,0.35);
}
#memberModal .btn-primary:hover {
  box-shadow: 0 6px 28px rgba(46,204,113,0.5);
  transform: translateY(-1px);
}
#memberModal .btn-primary:active { transform: translateY(0); }

/* ── OTP input ── */
.otp-input-row { display: flex; gap: 0.5rem; margin-top: 0.5rem; }
.otp-input-row input {
  flex: 1;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  color: var(--text);
  padding: 0.85rem;
  font-size: 1.4rem;
  text-align: center;
  letter-spacing: 8px;
  font-family:'Be Vietnam Pro',sans-serif;
  font-weight: 700;
