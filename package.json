<script>
// ═══ BOOKING APP DEBUG ═══
async function bookingDebugTest() {
  const log = document.getElementById('bookingDebugLog');
  if (!log) return;
  const L = (msg, color) => {
    log.innerHTML += `<div style="color:${color||'#E6EDF3'}">${msg}</div>`;
    log.scrollTop = log.scrollHeight;
  };
  log.innerHTML = '';
  L('═══ BẮT ĐẦU TEST ' + new Date().toLocaleTimeString('vi-VN') + ' ═══', '#F39C12');

  // Bước 0: proxy health qua /api/sheet
  L('<br>🔌 Bước 0: Kiểm tra proxy /api/sheet...');
  try {
    const res = await fetch('/api/sheet?action=debugHeaders');
    const raw = await res.text();
    L(`   → HTTP ${res.status} | ${raw.length} chars | preview: ${raw.substring(0,150)}`, '#8B949E');
    if (raw.trim().startsWith('{') || raw.trim().startsWith('[')) {
      L('✅ Proxy /api/sheet OK — trả về JSON', '#2ECC71');
    } else if (raw.trim() === '') {
      L('❌ Proxy trả về RỖNG — GAS đang throw exception', '#E74C3C');
      L('   → Mở Apps Script → Executions → xem lỗi gần nhất', '#F39C12');
    } else {
      L('⚠️ Proxy trả về không phải JSON', '#F39C12');
      L('   → ' + raw.substring(0, 200), '#8B949E');
    }
  } catch(e) { L('❌ Proxy FAIL: ' + e.message, '#E74C3C'); }

  // Bước 1: readJson — đọc lịch hôm nay
  L('<br>📅 Bước 1: Đọc lịch đặt sân hôm nay...');
  try {
    const today = new Date().toLocaleDateString('vi-VN', {day:'2-digit',month:'2-digit',year:'numeric'}).split('/').reverse().join('-');
    const t0    = Date.now();
    const res   = await fetch(`/api/sheet?action=readJson&date=${encodeURIComponent(today)}`);
    const ms    = Date.now() - t0;
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data  = await res.json();
    const rows  = Array.isArray(data) ? data : (data.bookings || []);
    L(`✅ readJson OK — ${rows.length} booking hôm nay — ${ms}ms`, '#2ECC71');
    if (rows.length > 0) {
      const b = rows[0];
      L(`   → Đầu tiên: ${b.name||'?'} | ${b.court||'?'} | ${b.startHour||'?'} | status: ${b.status||'?'}`, '#8B949E');
    }
  } catch(e) { L('❌ readJson FAIL: ' + e.message, '#E74C3C'); }

  // Bước 2: readConfig — lấy giá/cấu hình sân
  L('<br>⚙️ Bước 2: Đọc config (giá sân, số sân)...');
  try {
    const t0  = Date.now();
    const res = await fetch('/api/sheet?action=readConfig');
    const ms  = Date.now() - t0;
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();
    if (data && typeof data === 'object') {
      const keys = Object.keys(data).slice(0,5).join(', ');
      L(`✅ readConfig OK — keys: ${keys}... — ${ms}ms`, '#2ECC71');
    } else {
      L(`⚠️ readConfig không hợp lệ: ${JSON.stringify(data).substring(0,80)}`, '#F39C12');
    }
  } catch(e) { L('❌ readConfig FAIL: ' + e.message, '#E74C3C'); }

  // Bước 3: write test (không thực sự gửi — chỉ test endpoint phản hồi)
  L('<br>✏️ Bước 3: Kiểm tra endpoint ghi (write probe)...');
  try {
    const t0  = Date.now();
    const res = await fetch('/api/sheet?action=ping');
    const ms  = Date.now() - t0;
    const raw = await res.text();
    L(`   → HTTP ${res.status} | ${ms}ms | raw: ${raw.substring(0,120)}`, '#8B949E');
    if (res.status < 500) {
      L(`✅ Endpoint /api/sheet phản hồi — ${ms}ms`, '#2ECC71');
    } else {
      L(`❌ Server error ${res.status} — GAS hoặc proxy có vấn đề`, '#E74C3C');
    }
  } catch(e) { L('❌ Write probe FAIL: ' + e.message, '#E74C3C'); }

  L('<br>═══ KẾT THÚC TEST ═══', '#F39C12');
  L('→ Nếu tất cả ✅: booking app kết nối GAS bình thường', '#8B949E');
  L('→ Bước 0 ❌: kiểm tra netlify/functions/proxy.js và redeploy', '#8B949E');
  L('→ Bước 1 ❌: Sheet "Bookings" không tồn tại hoặc GAS lỗi quyền', '#8B949E');
}
</script>
</body>
